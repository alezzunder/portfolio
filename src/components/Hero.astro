---
import type { Translations } from '../i18n/utils';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const { hero, file } = t;
---

<section id="hero">
  <div class="hero-inner">
    <p class="hero-location fade-up d1">
      <span class="dot"></span>
      {hero.location}
    </p>

    <h1 class="hero-name fade-up d2">
      {hero.name}
    </h1>

    <p class="hero-title fade-up d3">
      <span class="prompt">&gt; </span>
      {hero.title}<span class="cursor"></span>
    </p>

    <div class="hero-stack fade-up d4">
      {hero.stack.map((tech) => (
        <span class="stack-tag">{tech}</span>
      ))}
    </div>

    <div class="hero-ctas fade-up d5">
      <a href="#projects" class="btn-primary">{hero.cta_work}</a>
      <a href={file} download class="btn-secondary">{hero.cta_cv}</a>
    </div>
  </div>

  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
  </div>
</section>

<style>
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    padding: 7rem 0 4rem;
  }

  .hero-location {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px rgba(201, 153, 59, 0.6);
    flex-shrink: 0;
  }

  .hero-name {
    font-family: 'Karla', sans-serif;
    font-style: italic;
    font-weight: 800;
    font-size: clamp(3.5rem, 6.7vw, 8rem);
    line-height: 0.9;
    color: var(--text);
    letter-spacing: -0.03em;
    margin: 0 0 1.75rem;
  }

  .hero-title {
    display: flex;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.8rem, 1.8vw, 1rem);
    font-weight: 300;
    color: var(--muted);
    margin: 0 0 2.25rem;
  }

  .prompt {
    color: var(--accent);
    margin-right: 0.2rem;
  }

  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 3.5rem;
  }

  .stack-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.07em;
    color: var(--muted);
    border: 1px solid var(--border);
    padding: 0.25rem 0.65rem;
    cursor: default;
    transition: border-color 0.2s, color 0.2s;
  }

  /*.stack-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  } */

  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Decorative background */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .hero-grid {
    position: absolute;
    right: 0;
    top: 0;
    width: 50%;
    height: 100%;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 60px 60px;
    -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,0.4) 0%, transparent 70%);
    mask-image: linear-gradient(to left, rgba(0,0,0,0.4) 0%, transparent 70%);
  }

  .hero-glow {
    position: absolute;
    bottom: -80px;
    left: -10%;
    width: 55%;
    height: 65%;
    background: radial-gradient(ellipse, rgba(201,153,59,0.06) 0%, transparent 65%);
  }

  @media (max-width: 768px) {
    .hero-grid {
      width: 100%;
      -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,0.15) 0%, transparent 80%);
      mask-image: linear-gradient(to left, rgba(0,0,0,0.15) 0%, transparent 80%);
    }
  }
</style>
